# Copy this file to .env and fill in your values

# --- LLM Providers ---
# Provider selection: "google" (primary) | "mistral" | "openrouter" | "groq" (legacy)
# Fallback chains (on 429/5xx/timeout/malformed, or missing key):
#   google -> mistral -> openrouter ; mistral -> google -> openrouter ; groq -> openrouter
LLM_PROVIDER=google

# Google Generative AI (PRIMARY)
# Measured 2026-07-09 on eval_intent: gemini-2.5-flash 20/20 (the adoption bar)
GOOGLE_API_KEY=
GOOGLE_MODEL_ID=gemini-2.5-flash

# Mistral La Plateforme (FALLBACK #1 — takes over on Gemini free-tier 429s)
# mistral-large-latest measured 16/20 (medium: 13/20) — benchmark any change:
#   py eval_intent.py --provider mistral --model <id>
MISTRAL_API_KEY=
MISTRAL_MODEL_ID=mistral-large-latest

# OpenRouter (terminal fallback)
OPENROUTER_API_KEY=sk-or-v1-...
MODEL_ID=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq (legacy — kept for compatibility, not the primary anymore)
GROQ_API_KEY=
GROQ_MODEL_ID=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Judge ---
JUDGE_PROVIDER=google
JUDGE_MODEL_ID=gemini-2.5-flash
JUDGE_THRESHOLD=0.75
JUDGE_MAX_RETRIES=1

DATABASE_URL=sqlite+aiosqlite:///./data/texttoviz.db

# RAG
RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# LangFuse Cloud (https://cloud.langfuse.com)
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Tableau Server
TABLEAU_SERVER_URL=
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=
TABLEAU_SITE_ID=
TABLEAU_DEFAULT_PROJECT_ID=
TABLEAU_DATASOURCE_FILTER=
