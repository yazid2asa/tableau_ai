# Copy this file to .env and fill in your values

# --- LLM Providers ---
# Provider selection: "groq" | "openrouter" | "google"
LLM_PROVIDER=groq

# OpenRouter (fallback provider)
OPENROUTER_API_KEY=sk-or-v1-...
MODEL_ID=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Groq (primary — fast, OpenAI-compatible)
GROQ_API_KEY=gsk_...
GROQ_MODEL_ID=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google Generative AI (optional)
GOOGLE_API_KEY=
GOOGLE_MODEL_ID=gemini-2.0-flash

# --- Judge ---
JUDGE_PROVIDER=groq
JUDGE_MODEL_ID=llama-3.3-70b-versatile
JUDGE_THRESHOLD=0.75
JUDGE_MAX_RETRIES=1

DATABASE_URL=sqlite+aiosqlite:///./data/texttoviz.db

# RAG
RAG_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# LangFuse Cloud (https://cloud.langfuse.com)
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Tableau Server
TABLEAU_SERVER_URL=
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=
TABLEAU_SITE_ID=
TABLEAU_DEFAULT_PROJECT_ID=
TABLEAU_DATASOURCE_FILTER=
